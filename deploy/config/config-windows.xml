<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>Atlas</Name>
    <Version>0.7.0</Version>
    <Title>Atlas Installer</Title>
    <Publisher>fenglab</Publisher>
    <StartMenuDir>fenglab</StartMenuDir>
    <TargetDir>@ApplicationsDirX64@/fenglab</TargetDir>
    <ProductUrl>https://fenglab.xyz</ProductUrl>
    <InstallerWindowIcon>atlas</InstallerWindowIcon>
    <InstallerApplicationIcon>atlas</InstallerApplicationIcon>
    <Logo>atlas.png</Logo>
    <Watermark>watermark.png</Watermark>
    <RunProgram>@TargetDir@/Atlas/Atlas.exe</RunProgram>
    <RunProgramDescription>Run Atlas now.</RunProgramDescription>
    <MaintenanceToolName>MaintenanceTool</MaintenanceToolName>
    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>

    <RemoteRepositories>
        <Repository>
            <Url>https://neutracing.com/static/packages/windows</Url>
            <Enabled>1</Enabled>
            <DisplayName>repository 1</DisplayName>
        </Repository>
        <Repository>
            <Url>https://fenglab.xyz/static/packages/windows</Url>
            <Enabled>0</Enabled>
            <DisplayName>repository 2</DisplayName>
        </Repository>
    </RemoteRepositories>
</Installer>