<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>Atlas</Name>
    <Version>0.7.0</Version>
    <Title>Atlas Installer</Title>
    <Publisher>fenglab</Publisher>
    <StartMenuDir>fenglab</StartMenuDir>
    <TargetDir>/Applications/fenglab</TargetDir>
    <ProductUrl>__ATLAS_PRODUCT_URL__</ProductUrl>
    <InstallerWindowIcon>atlas</InstallerWindowIcon>
    <InstallerApplicationIcon>atlas</InstallerApplicationIcon>
    <RunProgram>@TargetDir@/Atlas.app/Contents/MacOS/Atlas</RunProgram>
    <RunProgramDescription>Run Atlas now.</RunProgramDescription>
    <MaintenanceToolName>MaintenanceTool</MaintenanceToolName>
    <MaintenanceToolIniFile>MaintenanceToolState.ini</MaintenanceToolIniFile>
    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>

    <RemoteRepositories>
        <Repository>
            <Url>__ATLAS_IFW_REPO_PRIMARY_URL__</Url>
            <Enabled>1</Enabled>
            <DisplayName>repository 1</DisplayName>
        </Repository>
        <Repository>
            <Url>__ATLAS_IFW_REPO_SECONDARY_URL__</Url>
            <Enabled>1</Enabled>
            <DisplayName>repository 2</DisplayName>
        </Repository>
        <Repository>
            <Url>__ATLAS_IFW_REPO_BACKUP_URL__</Url>
            <Enabled>0</Enabled>
            <DisplayName>repository 3</DisplayName>
        </Repository>
    </RemoteRepositories>
</Installer>
