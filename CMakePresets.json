{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "config-base",
      "hidden": true,
      "displayName": "base Configuration",
      "description": "Default build using Ninja generator",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-clang-cl-base",
      "hidden": true,
      "displayName": "Windows clang-cl base",
      "description": "Atlas Windows clang-cl + lld defaults for IDE and manual configure runs",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/src/3rdparty/build/ninja.exe",
        "CMAKE_C_COMPILER": {
          "type": "FILEPATH",
          "value": "C:/Program Files/LLVM/bin/clang-cl.exe"
        },
        "CMAKE_CXX_COMPILER": {
          "type": "FILEPATH",
          "value": "C:/Program Files/LLVM/bin/clang-cl.exe"
        },
        "CMAKE_LINKER": {
          "type": "FILEPATH",
          "value": "C:/Program Files/LLVM/bin/lld-link.exe"
        }
      }
    },
    {
      "name": "Release",
      "displayName": "Config Release",
      "description": "Sets Release build type",
      "inherits": "config-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/src/3rdparty/build/ninja",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-clang-cl-release",
      "displayName": "Windows clang-cl Release",
      "description": "Release configure matching Atlas' Windows clang-cl Ninja workflow",
      "inherits": "windows-clang-cl-base"
    }
  ],
  "buildPresets": [
    {
      "name": "build-base",
      "hidden": true,
      "configurePreset": "Release"
    },
    {
      "name": "Release",
      "displayName": "Build Release",
      "inherits": "build-base",
      "configurePreset": "Release",
      "configuration": "Release"
    },
    {
      "name": "windows-clang-cl-release",
      "displayName": "Build Windows clang-cl Release",
      "inherits": "build-base",
      "configurePreset": "windows-clang-cl-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-all",
      "displayName": "Test All",
      "configurePreset": "Release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": false
      }
    },
    {
      "name": "test-windows-clang-cl-release",
      "displayName": "Test Windows clang-cl Release",
      "configurePreset": "windows-clang-cl-release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": false
      }
    }
  ]
}
