#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../botan
buildDIR=$srcDIR/../__botan-build
installDIR=$currDIR/botan
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ ! -d $srcDIR ]
then
  echo ERROR: src folder $srcDIR does not exist.
  exit 1 # terminate and indicate error
fi

if [ -d $buildDIR ]
then
  rm -rf $buildDIR
fi
mkdir $buildDIR
#cd %buildDIR
cd $srcDIR

$srcDIR/configure.py --cc=clang --cc-abi-flags="-mmacosx-version-min=10.8 -stdlib=libc++ -std=c++14" --prefix=$installDIR

make -j $numCores install

rm Makefile
rm -rf build

cd $currDIR
rm -rf $buildDIR