#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../hdf5-1.10.0
buildDIR=$srcDIR/../__hdf5-build
installDIR=$currDIR/hdf5
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ ! -d $srcDIR ]
then
  srcPackageDIR="/Users/feng/Google Drive/code/my"
  srcArchive=$srcPackageDIR/hdf5-1.10.0.tar.bz2
  tar -jxvf "$srcArchive" -C $currDIR/../../..
fi

if [ -d $buildDIR ]
then
  rm -rf $buildDIR
fi
mkdir $buildDIR
cd $buildDIR

cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$installDIR -DCMAKE_OSX_DEPLOYMENT_TARGET=10.7 -DCMAKE_OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.11.sdk -DBUILD_TESTING:BOOL="0" -DHDF5_ENABLE_DEPRECATED_SYMBOLS:BOOL="0" -DHDF5_ENABLE_Z_LIB_SUPPORT:BOOL="1" -DHDF5_ENABLE_THREADSAFE:BOOL="0" -DHDF5_BUILD_EXAMPLES:BOOL="0" -DCMAKE_CXX_FLAGS:STRING="${CMAKE_CXX_FLAGS} -stdlib=libc++ -std=c++14" $srcDIR

make -j $numCores install

cd $currDIR
rm -rf $buildDIR