#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../OSPRay
buildDIR=$srcDIR/../__OSPRay-build
installDIR=$currDIR/ospray
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ -d $srcDIR ]
then
  cd $srcDIR
  git pull
else
  git clone git@github.com:ospray/OSPRay.git $srcDIR
fi

# patch ./Modules/Core/Common/include/itkLightObject.h
#sed -i.bak 's/SET(CMAKE_CXX_FLAGS "-fPIC/SET(CMAKE_CXX_FLAGS "-stdlib=libc++ -std=c++14 -fPIC/' $srcDIR/cmake/clang.cmake

if [ -d $buildDIR ]
then
  rm -rf $buildDIR
fi
mkdir $buildDIR
cd $buildDIR

cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$installDIR -DCMAKE_OSX_DEPLOYMENT_TARGET=10.7 -DCMAKE_OSX_SYSROOT:PATH="/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.11.sdk" -DTBB_ROOT:PATH="/opt/intel/tbb" -DOSPRAY_BUILD_ISA:STRING="ALL" -DOSPRAY_MODULE_TACHYON:BOOL="1" -DOSPRAY_APPS_QTVIEWER:BOOL="0" -DOSPRAY_MODULE_SEISMIC:BOOL="0" -DOSPRAY_APPS_VOLUMEVIEWER:BOOL="0" -DOSPRAY_APPS_MODELVIEWER:BOOL="0" -DCMAKE_CXX_FLAGS:STRING="${CMAKE_CXX_FLAGS} -stdlib=libc++ -std=c++14" $srcDIR

make -j $numCores install

#unpatch
#mv -f $srcDIR/cmake/clang.cmake.bak $srcDIR/cmake/clang.cmake

cd $currDIR
rm -rf $buildDIR