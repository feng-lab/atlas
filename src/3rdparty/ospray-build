#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../OSPRay
buildDIR=$srcDIR/../__OSPRay-build
installDIR=$currDIR/ospray
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ ! -d $srcDIR ]
then
  echo ERROR: src folder $srcDIR does not exist.
  exit 1 # terminate and indicate error
fi

if [ -d $buildDIR ]
then
  rm -rf $buildDIR
fi
mkdir $buildDIR
cd $buildDIR

OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.12.sdk
if [ ! -d $OSX_SYSROOT ]
then
  OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.10.sdk
fi

cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$installDIR -DCMAKE_OSX_DEPLOYMENT_TARGET=10.8 -DCMAKE_OSX_SYSROOT:PATH=$OSX_SYSROOT -DTBB_ROOT:PATH="/opt/intel/tbb" -DOSPRAY_BUILD_ISA:STRING="ALL" -DOSPRAY_MODULE_TACHYON:BOOL="1" -DOSPRAY_APPS_QTVIEWER:BOOL="0" -DOSPRAY_MODULE_SEISMIC:BOOL="0" -DOSPRAY_APPS_VOLUMEVIEWER:BOOL="0" -DOSPRAY_APPS_MODELVIEWER:BOOL="0" -DCMAKE_CXX_FLAGS:STRING="${CMAKE_CXX_FLAGS} -stdlib=libc++ -std=c++14" $srcDIR

make -j $numCores install

cd $currDIR
rm -rf $buildDIR