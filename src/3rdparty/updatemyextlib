#!/bin/bash

srcPackageDIR="/Users/feng/Google Drive/code/my"
baseDIR=/Users/feng/code
currDIR="$( cd -P "$( dirname "$0" )" && pwd )"

if [[ "$OSTYPE" == "msys" ]]; then
  srcPackageDIR="/z/Google Drive/code/my"
  baseDIR=/c/Users/feng/code
fi

if [ -d $baseDIR/FreeImage ]
then
  rm -rf $baseDIR/FreeImage
fi
srcArchive=$srcPackageDIR/FreeImage3170.zip
7z x -y -o$baseDIR "$srcArchive"

if [ -d $baseDIR/libjpeg-turbo-1.4.2 ]
then
  rm -rf $baseDIR/libjpeg-turbo-1.4.2
fi
srcArchive=$srcPackageDIR/libjpeg-turbo-1.4.2.tar.gz
tar -zxf "$srcArchive" -C $baseDIR

if [ -d $baseDIR/hdf5-1.8.16 ]
then
  rm -rf $baseDIR/hdf5-1.8.16
fi
srcArchive=$srcPackageDIR/hdf5-1.8.16.tar.bz2
tar -jxf "$srcArchive" -C $baseDIR

if [ -d $baseDIR/GeometricTools ]
then
  rm -rf $baseDIR/GeometricTools
fi
srcArchive=$srcPackageDIR/GeometricTools/GeometricToolsEngine2p2.zip
7z x -y -o$baseDIR "$srcArchive"

if [[ "$OSTYPE" == "msys" ]]; then
  if [ -d $baseDIR/ispc-v1.8.2-windows ]
  then
    rm -rf $baseDIR/ispc-v1.8.2-windows
  fi
  srcArchive=$srcPackageDIR/ispc-v1.8.2-windows.zip
  7z x -y -o$baseDIR "$srcArchive"

  if [ -d $baseDIR/zlib-1.2.8 ]
  then
    rm -rf $baseDIR/zlib-1.2.8
  fi
  srcArchive=$srcPackageDIR/zlib128.zip
  7z x -y -o$baseDIR "$srcArchive"
else
  if [ -d $baseDIR/ispc-v1.8.2-osx ]
  then
    rm -rf $baseDIR/ispc-v1.8.2-osx
  fi
  srcArchive=$srcPackageDIR/ispc-v1.8.2-osx.tar.gz
  tar -zxf "$srcArchive" -C $baseDIR

  srcArchive=$srcPackageDIR/ffmpeg-3.0.7z
  7z x -y -o$baseDIR/atlas "$srcArchive"
fi

if [ -d $currDIR/boost ]
then
  rm -rf $currDIR/boost
fi
srcArchive=$srcPackageDIR/boost_1_60_0.tar.bz2
tar -jxf "$srcArchive" -C $currDIR
mv $currDIR/boost_1_60_0 $currDIR/boost

if [ -d $currDIR/eigen ]
then
  rm -rf $currDIR/eigen
fi
srcArchive=$srcPackageDIR/eigen-eigen-07105f7124f9.tar.bz2
tar -jxf "$srcArchive" -C $currDIR
mv $currDIR/eigen-eigen-07105f7124f9 $currDIR/eigen

if [ -d $currDIR/glm ]
then
  rm -rf $currDIR/glm
fi
srcArchive=$srcPackageDIR/glm-master.zip
7z x -y -o$currDIR "$srcArchive"
mv $currDIR/glm-master $currDIR/glm
