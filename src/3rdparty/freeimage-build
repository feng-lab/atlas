#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../FreeImage
buildDIR=$srcDIR/../__freeimage-build
installDIR=$currDIR/freeimage
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ ! -d $srcDIR ]
then
  echo ERROR: src folder $srcDIR does not exist.
  exit 1 # terminate and indicate error
fi

cp $currDIR/freeimage-makefiles/Makefile_gnu $srcDIR/
cp $currDIR/freeimage-makefiles/Makefile_fip $srcDIR/
cd $srcDIR

# patch to build on OSX
$currDIR/massedit.py -w -e "re.sub(r',0,0x80,', ',0,static_cast<signed char>(0x80),', line)" -e "re.sub(r',1,0x80,', ',1,static_cast<signed char>(0x80),', line)" -e "re.sub(r',0,0x88,', ',0,static_cast<signed char>(0x88),', line)" -e "re.sub(r',1,0x88,', ',1,static_cast<signed char>(0x88),', line)" -e "re.sub(r'DCRAW_VERSION', ' DCRAW_VERSION', line)" $srcDIR/Source/LibRawLite/internal/dcraw_common.cpp
$currDIR/massedit.py -w -e "re.sub(r'offset,offset,offset', 'static_cast<int16_t>(offset),static_cast<int16_t>(offset),static_cast<int16_t>(offset)', line)" $srcDIR/Source/LibRawLite/internal/libraw_x3f.cpp

make -f Makefile_gnu -j $numCores
make -f Makefile_gnu -j $numCores install PREFIX=$installDIR
make -f Makefile_gnu clean
make -f Makefile_fip -j $numCores
make -f Makefile_fip -j $numCores install PREFIX=$installDIR
make -f Makefile_fip clean

rm $srcDIR/Makefile_gnu
rm $srcDIR/Makefile_fip

install_name_tool -id $installDIR/lib/libfreeimage.dylib $installDIR/lib/libfreeimage.dylib
install_name_tool -id $installDIR/lib/libfreeimageplus.dylib $installDIR/lib/libfreeimageplus.dylib

#unpatch
mv -f $srcDIR/Source/LibRawLite/internal/dcraw_common.cpp.bak $srcDIR/Source/LibRawLite/internal/dcraw_common.cpp
mv -f $srcDIR/Source/LibRawLite/internal/libraw_x3f.cpp.bak $srcDIR/Source/LibRawLite/internal/libraw_x3f.cpp

cd $currDIR