#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../libpng-1.6.25
buildDIR=$srcDIR/../__libpng-build
installDIR=$currDIR/libpng
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ ! -d $srcDIR ]
then
  echo ERROR: src folder $srcDIR does not exist.
  exit 1 # terminate and indicate error
fi

# patch to ignore libpng warnings if we want to skip IDAT chunks, line 809
$currDIR/massedit.py -w -e "re.sub(r'                \|\| \(png_ptr->mode & PNG_HAVE_CHUNK_AFTER_IDAT\) != 0\)', r'&& 0)', line)" $srcDIR/pngread.c

if [ -d $buildDIR ]
then
  rm -rf $buildDIR
fi
mkdir $buildDIR
cd $buildDIR

OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.12.sdk
if [ ! -d $OSX_SYSROOT ]
then
  OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.11.sdk
fi
if [ ! -d $OSX_SYSROOT ]
then
  OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.10.sdk
fi

cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$installDIR -DCMAKE_OSX_DEPLOYMENT_TARGET=10.8 -DCMAKE_OSX_SYSROOT=$OSX_SYSROOT -DPNG_TESTS:BOOL="0" -DPNG_SHARED:BOOL="0" $srcDIR

make -j $numCores install

# unpatch
mv -f $srcDIR/pngread.c.bak $srcDIR/pngread.c

cd $currDIR
rm -rf $buildDIR