#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../jxrlib
buildDIR=$srcDIR/../__jxrlib-build
installDIR=$currDIR/jxrlib

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ -d $srcDIR ]
then
  cd $srcDIR
  git pull
else
  git clone https://git01.codeplex.com/jxrlib $srcDIR
fi

cd $srcDIR

# patch to avoid error: explicit specialization of 'ZERO_TOLERANCE' after instantiation
sed -i.bak 's/CFLAGS=/CFLAGS=-mmacosx-version-min=10.7 /' $srcDIR/Makefile

make -j8 install DIR_INSTALL=$installDIR

rm -r $srcDIR/build

#unpatch
mv -f $srcDIR/Makefile.bak $srcDIR/Makefile

cd $currDIR