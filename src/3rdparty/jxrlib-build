#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../jxrlib
buildDIR=$srcDIR/../__jxrlib-build
installDIR=$currDIR/jxrlib
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ -d $srcDIR ]
then
  cd $srcDIR
  git pull
else
  git clone https://git01.codeplex.com/jxrlib $srcDIR
fi

cd $srcDIR

# patch
$currDIR/massedit.py -w -e "re.sub(r'CFLAGS=', r'CFLAGS=-mmacosx-version-min=10.8 ', line)" $srcDIR/Makefile

make -j $numCores install DIR_INSTALL=$installDIR

rm -r $srcDIR/build

#unpatch
mv -f $srcDIR/Makefile.bak $srcDIR/Makefile

cd $currDIR