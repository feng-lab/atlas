#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../GeometricTools/WildMagic5
buildDIR=$srcDIR/../__wildmagic-build
installDIR=$currDIR/wildmagic
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

cd $srcDIR

# patch to avoid error: explicit specialization of 'ZERO_TOLERANCE' after instantiation
sed -i.bak 's/Mathf::ZERO_TOLERANCE/1e-06f/' $srcDIR/LibMathematics/Algebra/Wm5AVector.h
sed -i.bak 's/Mathf::ZERO_TOLERANCE/1e-06f/' $srcDIR/LibMathematics/Algebra/Wm5HPlane.h
sed -i.bak 's/Mathf::ZERO_TOLERANCE/1e-06f/' $srcDIR/LibMathematics/Algebra/Wm5HQuaternion.h

cd LibCore
chmod +x *.sh
xcodebuild -project LibCore.xcodeproj -configuration Default -target "Release Static" build -arch x86_64 MACOSX_DEPLOYMENT_TARGET=10.7 OTHER_CPLUSPLUSFLAGS="-std=c++14 -stdlib=libc++"
cd ..

cd LibMathematics
chmod +x *.sh
xcodebuild -project LibMathematics.xcodeproj -configuration Default -target "Release Static" build -arch x86_64 MACOSX_DEPLOYMENT_TARGET=10.7 OTHER_CPLUSPLUSFLAGS="-std=c++14 -stdlib=libc++"
cd ..

cp -R $srcDIR/SDK/ $installDIR

#unpatch
mv -f $srcDIR/LibMathematics/Algebra/Wm5AVector.h.bak $srcDIR/LibMathematics/Algebra/Wm5AVector.h
mv -f $srcDIR/LibMathematics/Algebra/Wm5HPlane.h.bak $srcDIR/LibMathematics/Algebra/Wm5HPlane.h
mv -f $srcDIR/LibMathematics/Algebra/Wm5HQuaternion.h.bak $srcDIR/LibMathematics/Algebra/Wm5HQuaternion.h

cd $currDIR