#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../opencv
srcContribDIR=$currDIR/../../../opencv_contrib
buildDIR=$srcDIR/../__opencv-build
installDIR=$currDIR/opencv
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ ! -d $srcDIR ]
then
  echo ERROR: src folder $srcDIR does not exist.
  exit 1 # terminate and indicate error
fi

if [ ! -d $srcContribDIR ]
then
  echo ERROR: src folder $srcContribDIR does not exist.
  exit 1 # terminate and indicate error
fi

# patch
$currDIR/massedit.py -w -e "re.sub(r'stdc\+\+', r'', line)" $srcDIR/cmake/OpenCVCompilerOptions.cmake

if [ -d $buildDIR ]
then
  rm -rf $buildDIR
fi
mkdir $buildDIR
cd $buildDIR

OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.12.sdk
if [ ! -d $OSX_SYSROOT ]
then
  OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.11.sdk
fi
if [ ! -d $OSX_SYSROOT ]
then
  OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.10.sdk
fi

cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$installDIR -DCMAKE_OSX_DEPLOYMENT_TARGET=10.8 -DCMAKE_OSX_SYSROOT=$OSX_SYSROOT -DCMAKE_CXX_FLAGS:STRING="${CMAKE_CXX_FLAGS} -stdlib=libc++ -std=c++14" -DIPPROOT="/opt/intel/ipp" -DBUILD_WITH_DYNAMIC_IPP:BOOL="0" -DWITH_PTHREADS_PF:BOOL="0" -DBUILD_opencv_videoio:BOOL="0" -DBUILD_SHARED_LIBS:BOOL="0" -DBUILD_opencv_python2:BOOL="0" -DBUILD_opencv_videostab:BOOL="1" -DEIGEN_INCLUDE_PATH:PATH="$currDIR/eigen" -DBUILD_opencv_world:BOOL="0" -DWITH_TBB:BOOL="1" -DWITH_VTK:BOOL="0" -DBUILD_PERF_TESTS:BOOL="0" -DWITH_PNG:BOOL="0" -DWITH_FFMPEG:BOOL="0" -DWITH_QUICKTIME:BOOL="0" -DWITH_1394:BOOL="0" -DWITH_GSTREAMER:BOOL="0" -DBUILD_DOCS:BOOL="0" -DBUILD_PNG:BOOL="0" -DWITH_GPHOTO2:BOOL="0" -DBUILD_ZLIB:BOOL="0" -DWITH_CUDA:BOOL="0" -DWITH_PVAPI:BOOL="0" -DBUILD_JASPER:BOOL="0" -DOPENCV_EXTRA_MODULES_PATH:PATH="$srcContribDIR/modules" -DBUILD_TESTS:BOOL="0" -DBUILD_JPEG:BOOL="0" -DBUILD_TIFF:BOOL="0" -DWITH_LIBV4L:BOOL="0" -DWITH_GIGEAPI:BOOL="0" -DBUILD_opencv_video:BOOL="1" -DWITH_V4L:BOOL="0" -DWITH_WEBP:BOOL="0" -DWITH_TIFF:BOOL="0" -DBUILD_FAT_JAVA_LIB:BOOL="0" -DBUILD_OPENEXR:BOOL="0" -DWITH_CUFFT:BOOL="1" -DWITH_JPEG:BOOL="0" -DWITH_OPENEXR:BOOL="0" -DBUILD_PACKAGE:BOOL="0" -DWITH_JASPER:BOOL="0" -DBUILD_WITH_DEBUG_INFO:BOOL="0" -DBUILD_opencv_apps:BOOL="0" -DBUILD_opencv_matlab:BOOL="0" $srcDIR

make -j $numCores install

# unpatch
mv -f $srcDIR/cmake/OpenCVCompilerOptions.cmake.bak $srcDIR/cmake/OpenCVCompilerOptions.cmake

# patch cmake module
$currDIR/massedit.py -w -e "re.sub(r';libtbb.dylib;ippcore;ipps;ippi;ippcc;ippcv;ippvm;/opt/intel/compilers_and_libraries_2017.0.102/mac/compiler/lib/libirc.dylib;/opt/intel/compilers_and_libraries_2017.0.102/mac/compiler/lib/libimf.dylib;/opt/intel/compilers_and_libraries_2017.0.102/mac/compiler/lib/libsvml.dylib', r'', line)" $installDIR/share/OpenCV/OpenCVModules-release.cmake

cd $currDIR
rm -rf $buildDIR