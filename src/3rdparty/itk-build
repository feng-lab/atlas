#!/bin/bash

currDIR="$( cd -P "$( dirname "$0" )" && pwd )"
srcDIR=$currDIR/../../../ITK
buildDIR=$srcDIR/../__itk-build
installDIR=$currDIR/itk
numCores=$( sysctl -n hw.logicalcpu )

if [ -d $installDIR ]
then
  rm -rf $installDIR
fi

if [ -d $srcDIR ]
then
  cd $srcDIR
  git pull
else
  git clone git://itk.org/ITK.git $srcDIR
fi

# patch ./Modules/Core/Common/include/itkLightObject.h
sed -i.bak 's/#elif defined( __APPLE__ ) && ( MAC_OS_X_VERSION_MIN_REQUIRED >= 1050 )/#elif defined( __APPLE__ )/' $srcDIR/Modules/Core/Common/include/itkLightObject.h

if [ -d $buildDIR ]
then
  rm -rf $buildDIR
fi
mkdir $buildDIR
cd $buildDIR

cmake -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$installDIR -DCMAKE_OSX_DEPLOYMENT_TARGET=10.7 -DCMAKE_OSX_SYSROOT=/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX10.11.sdk -DBUILD_EXAMPLES:BOOL="0" -DBUILD_TESTING:BOOL="0" -DITK_USE_64BITS_IDS:BOOL="1" -DITK_LEGACY_REMOVE:BOOL="1" -DITK_USE_GPU:BOOL="1" -DITK_DOXYGEN_HTML:BOOL="0" -DITK_USE_STRICT_CONCEPT_CHECKING:BOOL="1" -DModule_ITKReview:BOOL="1" -DITK_USE_SYSTEM_ZLIB:BOOL="1" -DCMAKE_CXX_FLAGS:STRING="${CMAKE_CXX_FLAGS} -stdlib=libc++ -std=c++14" $srcDIR

make -j $numCores install

#unpatch
mv -f $srcDIR/Modules/Core/Common/include/itkLightObject.h.bak $srcDIR/Modules/Core/Common/include/itkLightObject.h

cd $currDIR
rm -rf $buildDIR